.idea

# build output
dist/
.output/

# dependencies
node_modules/

# logs
*.log

# Environment files (contain secrets — never commit)
.env
.env.local
.env.*
!.env.example

# Infrastructure secrets (never commit these)
infra/deploy/overlays/*/.env.secrets
infra/deploy/overlays/*/.env.*.merged
/tmp/.env.*

# Keep infrastructure env files (they contain no secrets, just placeholders)
# infra/deploy/overlays/*/.env.* files are tracked

# Strapi
.tmp/
.cache/
build/
strapi/public/uploads/

# Spec/reference files (not source code)
spec/mail-html/

# Docker postgres volume
/data

# macOS-specific files
.DS_Store

# Accessibility audit artifacts
.claude/skills/accessibility/a11y-audit/last-audit.json
.claude/skills/accessibility/a11y-audit/node_modules/

# SEO audit artifacts
.claude/skills/seo/last-audit.json
.claude/skills/seo/lighthouse-*.json

