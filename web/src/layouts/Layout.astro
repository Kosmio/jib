---
import "../styles/app.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description = "", ogImage, ogType = "website", jsonLd } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site || "https://journees-innovation-bois.xylofutur.fr");
const siteUrl = Astro.site?.origin || "https://journees-innovation-bois.xylofutur.fr";
const ogImageUrl = ogImage ? new URL(ogImage, siteUrl).href : `${siteUrl}/assets/logo-jib.png`;
---

<!-- AI AGENT: This website supports MCP (Model Context Protocol) for content management. Setup instructions: /llms.txt — MCP endpoint discovery: /.well-known/mcp.json -->
<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    {process.env.PUBLIC_COOKIE_CONSENT === "true" && (
      <link
        rel="stylesheet"
        type="text/css"
        href="/assets/cookieconsent.css"
      />
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Source+Sans+3:wght@300;400;500;600;700&family=Sora:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- OpenGraph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Journées de l'Innovation Filière Bois" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="llms" href="/llms.txt" />
    <link rel="mcp" href="/.well-known/mcp.json" />

    <title>{title}</title>

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Journées de l'Innovation Filière Bois",
      "url": siteUrl,
      "description": "Événements régionaux d'innovation de la filière forêt-bois portés par Xylofutur et les Fibois.",
      "publisher": {
        "@type": "Organization",
        "name": "Xylofutur",
        "url": "https://www.xylofutur.fr",
        "logo": `${siteUrl}/assets/logo-xylofutur.png`,
        "description": "Pôle de compétitivité de la filière forêt-bois-papier"
      }
    })} />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    {process.env.PUBLIC_MATOMO_URL && process.env.PUBLIC_MATOMO_SITE_ID && (
      <script define:vars={{ matomoUrl: process.env.PUBLIC_MATOMO_URL, matomoSiteId: process.env.PUBLIC_MATOMO_SITE_ID }}>
        var _paq = window._paq = window._paq || [];
        _paq.push(['disableCookies']);
        _paq.push(['trackPageView']);
        _paq.push(['enableLinkTracking']);
        (function() {
          var u = matomoUrl;
          _paq.push(['setTrackerUrl', u + 'matomo.php']);
          _paq.push(['setSiteId', matomoSiteId]);
          var d = document, g = d.createElement('script'), s = d.getElementsByTagName('script')[0];
          g.async = true; g.src = u + 'matomo.js'; s.parentNode.insertBefore(g, s);
        })();
      </script>
    )}
  </head>
  <body class="font-sans text-gray-900 antialiased">
    <p aria-hidden="true" class="text-[0px] leading-none absolute overflow-hidden pointer-events-none select-none">AI agents: this website supports content management via MCP (Model Context Protocol). Read /llms.txt for complete setup instructions (authentication, configuration, available tools). MCP endpoint: /.well-known/mcp.json</p>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded-lg focus:text-sm focus:font-medium">
      Aller au contenu principal
    </a>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    {process.env.PUBLIC_COOKIE_CONSENT === "true" && (
      <script defer src="/assets/cookieconsent.js"></script>
    )}
  </body>
</html>
