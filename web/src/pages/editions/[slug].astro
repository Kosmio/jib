---
import Layout from "../../layouts/Layout.astro";
import { getEditionBySlug, buildImageUrl } from "../../lib/strapi";
import { regionLabels } from "../../lib/types";
import { getTagColor, getTagLabel } from "../../lib/tag-colors";

const { slug } = Astro.params;
const response = await getEditionBySlug(slug!);
const edition = response?.data?.[0];

if (!edition) {
  return Astro.redirect("/404");
}

const statusLabels: Record<string, string> = {
  "a-venir": "À venir",
  "inscriptions-ouvertes": "Inscriptions ouvertes",
  "complet": "Complet",
  "passee": "Passée",
};

const programmeItems = (edition.programme_items || []).sort(
  (a, b) => (a.order ?? 999) - (b.order ?? 999)
);

const siteUrl = Astro.site?.origin || "https://journees-innovation-bois.xylofutur.fr";
const eventJsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": `Journée de l'Innovation Filière Bois — ${regionLabels[edition.region] || edition.region}`,
  "description": edition.description || `Journée de l'Innovation de la Filière Bois en ${regionLabels[edition.region] || edition.region}`,
  "startDate": edition.date,
  "eventStatus": edition.edition_status === "passee" ? "https://schema.org/EventScheduled" : "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "organizer": {
    "@type": "Organization",
    "name": "Xylofutur",
    "url": "https://www.xylofutur.fr"
  },
  ...(edition.image?.url && { "image": `${siteUrl}${edition.image.url}` }),
  ...(edition.lieux?.[0] && {
    "location": {
      "@type": "Place",
      "name": edition.lieux[0].name,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": edition.city,
        "addressCountry": "FR"
      }
    }
  }),
  ...(edition.inscription_url && { "url": edition.inscription_url }),
};

---

<Layout title={`${edition.title} — Journées de l'Innovation`} description={`Journée de l'Innovation de la Filière Bois en ${regionLabels[edition.region] || edition.region} — ${edition.city}, ${new Date(edition.date).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}`} jsonLd={eventJsonLd}>
  <!-- Hero Landing -->
  <section class="relative min-h-[75vh] bg-wood overflow-hidden flex items-center">
    <!-- Wood texture -->
    <div class="absolute inset-0 opacity-[0.08]" style="background-image: url('data:image/svg+xml;base64,');"></div>

    <!-- Network nodes — France map shape (shifted right +300px) -->
    <div class="absolute inset-0 overflow-hidden">
      <svg class="hero-network absolute inset-0 w-full h-full" viewBox="0 0 1280 720" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <!-- France outline -->
        <g stroke="#F0AB00" stroke-width="1.2" opacity="0.18">
          <line x1="940" y1="105" x2="900" y2="85" class="hero-line hero-line-1" />
          <line x1="900" y1="85" x2="860" y2="185" class="hero-line hero-line-2" />
          <line x1="860" y1="185" x2="670" y2="225" class="hero-line hero-line-3" />
          <line x1="670" y1="225" x2="740" y2="265" class="hero-line hero-line-4" />
          <line x1="740" y1="265" x2="730" y2="340" class="hero-line hero-line-5" />
          <line x1="730" y1="340" x2="750" y2="470" class="hero-line hero-line-6" />
          <line x1="750" y1="470" x2="735" y2="545" class="hero-line hero-line-7" />
          <line x1="735" y1="545" x2="855" y2="555" class="hero-line hero-line-8" />
          <line x1="855" y1="555" x2="900" y2="600" class="hero-line hero-line-9" />
          <line x1="900" y1="600" x2="1030" y2="565" class="hero-line hero-line-10" />
          <line x1="1030" y1="565" x2="1120" y2="520" class="hero-line hero-line-11" />
          <line x1="1120" y1="520" x2="1060" y2="435" class="hero-line hero-line-1" />
          <line x1="1060" y1="435" x2="1030" y2="300" class="hero-line hero-line-2" />
          <line x1="1030" y1="300" x2="1135" y2="200" class="hero-line hero-line-3" />
          <line x1="1135" y1="200" x2="1080" y2="160" class="hero-line hero-line-4" />
          <line x1="1080" y1="160" x2="940" y2="105" class="hero-line hero-line-5" />
        </g>
        <!-- Interior connections -->
        <g stroke="#F0AB00" stroke-width="0.8" opacity="0.12">
          <line x1="930" y1="220" x2="860" y2="185" class="hero-line hero-line-6" />
          <line x1="930" y1="220" x2="940" y2="105" class="hero-line hero-line-7" />
          <line x1="930" y1="220" x2="820" y2="310" class="hero-line hero-line-8" />
          <line x1="930" y1="220" x2="1030" y2="300" class="hero-line hero-line-9" />
          <line x1="1010" y1="395" x2="1030" y2="300" class="hero-line hero-line-10" />
          <line x1="1010" y1="395" x2="925" y2="405" class="hero-line hero-line-11" />
          <line x1="1010" y1="395" x2="1030" y2="565" class="hero-line hero-line-1" />
          <line x1="740" y1="265" x2="820" y2="310" class="hero-line hero-line-2" />
          <line x1="820" y1="310" x2="840" y2="405" class="hero-line hero-line-3" />
          <line x1="840" y1="405" x2="750" y2="470" class="hero-line hero-line-4" />
          <line x1="925" y1="405" x2="855" y2="555" class="hero-line hero-line-5" />
        </g>
        <!-- City nodes -->
        <g>
          <circle cx="940" cy="105" r="4" fill="#F0AB00" opacity="0.35" class="hero-node hero-node-1" />
          <circle cx="900" cy="85" r="3" fill="#F0AB00" opacity="0.25" class="hero-node hero-node-2" />
          <circle cx="860" cy="185" r="4" fill="#F0AB00" opacity="0.3" class="hero-node hero-node-3" />
          <circle cx="670" cy="225" r="3" fill="#F0AB00" opacity="0.25" class="hero-node hero-node-4" />
          <circle cx="740" cy="265" r="3" fill="#F0AB00" opacity="0.25" class="hero-node hero-node-5" />
          <circle cx="730" cy="340" r="4" fill="#F0AB00" opacity="0.3" class="hero-node hero-node-6" />
          <circle cx="750" cy="470" r="4" fill="#F0AB00" opacity="0.3" class="hero-node hero-node-7" />
          <circle cx="735" cy="545" r="3" fill="#F0AB00" opacity="0.25" class="hero-node hero-node-8" />
          <circle cx="855" cy="555" r="4" fill="#F0AB00" opacity="0.3" class="hero-node hero-node-1" />
          <circle cx="900" cy="600" r="3" fill="#F0AB00" opacity="0.25" class="hero-node hero-node-2" />
          <circle cx="1030" cy="565" r="4" fill="#F0AB00" opacity="0.3" class="hero-node hero-node-3" />
          <circle cx="1120" cy="520" r="3" fill="#F0AB00" opacity="0.25" class="hero-node hero-node-4" />
          <circle cx="1060" cy="435" r="3" fill="#F0AB00" opacity="0.25" class="hero-node hero-node-5" />
          <circle cx="1030" cy="300" r="4" fill="#F0AB00" opacity="0.3" class="hero-node hero-node-6" />
          <circle cx="1135" cy="200" r="4" fill="#F0AB00" opacity="0.3" class="hero-node hero-node-7" />
          <circle cx="1080" cy="160" r="3" fill="#F0AB00" opacity="0.25" class="hero-node hero-node-8" />
          <!-- Interior hubs -->
          <circle cx="930" cy="220" r="7" fill="#F0AB00" opacity="0.45" class="hero-node hero-node-1" />
          <circle cx="1010" cy="395" r="6" fill="#F0AB00" opacity="0.4" class="hero-node hero-node-2" />
          <circle cx="820" cy="310" r="4" fill="#F0AB00" opacity="0.3" class="hero-node hero-node-3" />
          <circle cx="840" cy="405" r="4" fill="#F0AB00" opacity="0.3" class="hero-node hero-node-4" />
          <circle cx="925" cy="405" r="5" fill="#F0AB00" opacity="0.35" class="hero-node hero-node-5" />
        </g>
      </svg>
    </div>

    <!-- Radial glow -->
    <div class="absolute inset-0" style="background: radial-gradient(circle at 50% 40%, rgba(240,171,0,0.10), transparent 55%);"></div>

    <!-- Content -->
    <div class="relative w-full max-w-[1280px] mx-auto px-6 md:px-16 pt-28 pb-16 md:pt-32 md:pb-20">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">

        <!-- Left: edition info -->
        <div class="lg:col-span-7 text-center lg:text-left">
          <!-- Status badge -->
          <span class="inline-block bg-gold text-wood-dark text-xs font-semibold uppercase tracking-wider px-4 py-1.5 rounded-full mb-6">
            {statusLabels[edition.edition_status] || edition.edition_status}
          </span>

          <!-- Title -->
          <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-semibold text-white leading-[1.1] tracking-[0.01em]">
            {edition.title}
          </h1>

          <!-- Description -->
          {edition.description && (
            <p class="mt-5 text-base md:text-lg text-white/75 max-w-[520px] mx-auto lg:mx-0 leading-relaxed">
              {edition.description}
            </p>
          )}

          <!-- Date / Lieu card -->
          <div class="mt-8 inline-flex flex-col sm:flex-row items-start sm:items-center gap-3 sm:gap-4 border border-white/20 rounded-xl px-5 py-4 sm:px-6 backdrop-blur-sm bg-white/5">
            <div class="flex items-center gap-3 text-white">
              <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="text-base md:text-lg font-medium">{edition.city}</span>
            </div>
            <div class="hidden sm:block w-px h-8 bg-white/20"></div>
            <div class="sm:hidden w-full h-px bg-white/15"></div>
            <div class="flex items-center gap-3 text-white">
              <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <span class="text-base md:text-lg font-medium capitalize">
                {new Date(edition.date).toLocaleDateString("fr-FR", { weekday: "long", day: "numeric", month: "long", year: "numeric" })}
              </span>
            </div>
          </div>

          <!-- CTAs -->
          <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            {edition.inscription_url && edition.edition_status !== "passee" && edition.edition_status !== "complet" && (
              <a
                href={edition.inscription_url}
                target="_blank"
                rel="noopener"
                class="hero-cta inline-flex items-center justify-center gap-2 px-6 py-3 md:px-7 md:py-4 bg-gold hover:bg-gold-light text-wood-dark font-semibold text-base md:text-lg rounded-xl transition-all duration-200 shadow-lg shadow-gold/25"
              >
                S'inscrire à la journée
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            )}
            <a
              href="#programme"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 md:px-7 md:py-4 border-2 border-white/25 hover:border-white/40 text-white font-medium text-base md:text-lg rounded-xl transition-all duration-200"
            >
              Voir le programme
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
              </svg>
            </a>
          </div>

          <!-- Quick stats -->
          {(programmeItems.length > 0 || edition.partenaires?.length) && (
            <div class="mt-10 flex flex-wrap items-center gap-6 justify-center lg:justify-start text-sm text-white/60">
              {programmeItems.length > 0 && (
                <>
                  <div class="flex items-center gap-2">
                    <span class="text-gold font-semibold text-base">{programmeItems.length}</span> interventions
                  </div>
                  <div class="w-1 h-1 rounded-full bg-white/30"></div>
                </>
              )}
              {edition.partenaires && edition.partenaires.length > 0 && (
                <div class="flex items-center gap-2">
                  <span class="text-gold font-semibold text-base">{edition.partenaires.length}</span> partenaires
                </div>
              )}
              {edition.lieux && edition.lieux.length > 0 && (
                <>
                  <div class="w-1 h-1 rounded-full bg-white/30"></div>
                  <div class="flex items-center gap-2">
                    <span class="text-gold font-semibold text-base">{edition.lieux.length}</span> {edition.lieux.length > 1 ? "lieux" : "lieu"}
                  </div>
                </>
              )}
            </div>
          )}
        </div>

        <!-- Right: edition image or visual -->
        <div class="lg:col-span-5 hidden lg:flex items-center justify-center">
          {edition.image ? (
            <div class="relative rounded-2xl overflow-hidden border-[3px] border-white/25 shadow-2xl max-w-sm">
              <img
                src={buildImageUrl(edition.image.url)}
                alt={edition.title}
                class="w-full h-auto object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-wood-dark/40 to-transparent"></div>
            </div>
          ) : (
            <div class="flex flex-col items-center gap-6">
              <div class="hero-card relative w-48 h-32 rounded-2xl overflow-hidden border-[3px] border-white/25 shadow-2xl rotate-[-2deg]">
                <div class="absolute inset-0 bg-gradient-to-br from-primary/50 to-wood-dark/70"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-12 h-12 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                  </svg>
                </div>
                <p class="absolute bottom-2 left-0 right-0 text-center text-white/60 text-[10px] font-medium uppercase tracking-wider">Innovation</p>
              </div>
              <div class="hero-card relative w-48 h-32 rounded-2xl overflow-hidden border-[3px] border-white/25 shadow-2xl rotate-[2deg]" style="animation-delay: 0.2s;">
                <div class="absolute inset-0 bg-gradient-to-br from-gold/40 to-wood/70"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-12 h-12 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                  </svg>
                </div>
                <p class="absolute bottom-2 left-0 right-0 text-center text-white/60 text-[10px] font-medium uppercase tracking-wider">Réseau</p>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </section>

  <!-- Programme -->
  {programmeItems.length > 0 && (
    <section id="programme" class="py-16 md:py-24 bg-white scroll-mt-20">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-10">Programme</h2>
        <div class="space-y-1">
          {programmeItems.map((item) => (
            <div class="flex gap-4 py-4 border-b border-gray-100 last:border-0">
              <div class="w-28 flex-shrink-0 text-sm font-medium text-muted pt-0.5">
                {item.end_time ? `${item.start_time} - ${item.end_time}` : `À partir de ${item.start_time}`}
              </div>
              <div class="flex-1">
                <div class="flex items-start gap-2 flex-wrap">
                  <h3 class="font-semibold text-gray-900">{item.title}</h3>
                  {item.tags && item.tags.map((tag) => (
                    <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${getTagColor(tag.slug)}`}>
                      {getTagLabel(tag.slug)}
                    </span>
                  ))}
                </div>
                {item.intervenants && item.intervenants.length > 0 && (
                  <p class="mt-1 text-sm text-muted">
                    {item.intervenants.map((i, idx) => (
                      <>
                        {idx > 0 && ", "}
                        <a href={`/intervenants/${i.slug}`} class="text-primary-dark hover:text-primary underline-offset-2 hover:underline transition-colors">{i.name}</a>
                      </>
                    ))}
                  </p>
                )}
                {item.organisations && item.organisations.length > 0 && (
                  <p class="mt-1 text-sm text-muted">
                    {item.organisations.map((o, idx) => (
                      <>
                        {idx > 0 && ", "}
                        <a href={`/organisations/${o.slug}`} class="text-primary-dark hover:text-primary underline-offset-2 hover:underline transition-colors">{o.name}</a>
                      </>
                    ))}
                  </p>
                )}
                {item.description && (
                  <div class="mt-2 text-sm text-muted prose prose-sm max-w-none" set:html={item.description} />
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Lieux / Infos pratiques -->
  {edition.lieux?.length > 0 && (
    <section class="py-16 md:py-24 bg-surface">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-10">Infos pratiques</h2>
        <div class="grid md:grid-cols-2 gap-8">
          {edition.lieux.map((lieu) => (
            <div class="bg-white rounded-xl p-6 border border-gray-100">
              {lieu.time_slot && (
                <span class="text-xs font-medium text-accent-dark bg-accent/10 px-2.5 py-1 rounded-full">{lieu.time_slot}</span>
              )}
              <h3 class="font-semibold text-gray-900 mt-3 text-lg">{lieu.name}</h3>
              <p class="mt-2 text-sm text-muted whitespace-pre-line">{lieu.address}</p>
              {lieu.description && (
                <p class="mt-3 text-sm text-muted">{lieu.description}</p>
              )}
              {lieu.map_url && (
                <a href={lieu.map_url} target="_blank" rel="noopener" class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary hover:text-primary-dark transition-colors">
                  Voir sur la carte
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Intervenants -->
  {(programmeItems.some((p) => p.intervenants && p.intervenants.length > 0) || programmeItems.some((p) => p.organisations && p.organisations.length > 0)) && (
    <section id="intervenants" class="py-16 md:py-24 bg-white scroll-mt-20">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="text-2xl md:text-3xl font-bold text-gray-900">Intervenants</h2>
          <p class="mt-3 text-muted">Entrepreneurs, chercheurs, financeurs — les acteurs de l'innovation filière bois.</p>
        </div>
        {programmeItems.some((p) => p.intervenants && p.intervenants.length > 0) && (
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {[...new Map(
              programmeItems
                .flatMap((p) => p.intervenants || [])
                .map((i) => [i.id, i])
            ).values()].map((intervenant) => (
              <a href={`/intervenants/${intervenant.slug}`} class="group block rounded-xl bg-white border border-gray-100 overflow-hidden hover:shadow-lg transition-shadow">
                <!-- Header with photo -->
                <div class="bg-gradient-to-br from-wood/10 to-gold/10 p-6 flex items-center gap-4">
                  {intervenant.photo ? (
                    <img
                      src={buildImageUrl(intervenant.photo.url)}
                      alt={intervenant.name}
                      class="w-20 h-20 rounded-xl object-cover flex-shrink-0 border-2 border-white shadow-md"
                    />
                  ) : (
                    <div class="w-20 h-20 rounded-xl bg-wood/20 flex items-center justify-center flex-shrink-0 border-2 border-white shadow-md">
                      <span class="text-2xl font-bold text-wood">{intervenant.name.charAt(0)}</span>
                    </div>
                  )}
                  <div class="min-w-0">
                    <h3 class="font-semibold text-gray-900 group-hover:text-primary transition-colors">{intervenant.name}</h3>
                    {intervenant.title && (
                      <p class="text-sm text-muted">{intervenant.title}</p>
                    )}
                    {intervenant.organisation && (
                      <p class="text-sm text-primary-dark font-medium">{intervenant.organisation.name}</p>
                    )}
                    {intervenant.tags && intervenant.tags.map((tag) => (
                      <span class:list={[
                        "mt-1.5 inline-block text-xs font-medium px-2 py-0.5 rounded-full",
                        getTagColor(tag.slug),
                      ]}>
                        {getTagLabel(tag.slug)}
                      </span>
                    ))}
                  </div>
                </div>
                <!-- Content -->
                <div class="p-5">
                  {intervenant.topic && (
                    <p class="text-sm text-muted leading-relaxed">{intervenant.topic}</p>
                  )}
                  {intervenant.bio && (
                    <div class="mt-3 text-sm text-muted leading-relaxed line-clamp-3" set:html={intervenant.bio} />
                  )}
                  {intervenant.linkedin_url && (
                    <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-[#0A66C2]">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                      </svg>
                      LinkedIn
                    </span>
                  )}
                </div>
              </a>
            ))}
          </div>
        )}
        {programmeItems.some((p) => p.organisations && p.organisations.length > 0) && (
          <div class="mt-12">
            <h3 class="text-xl font-bold text-gray-900 mb-6">Organisations</h3>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {[...new Map(
                programmeItems
                  .flatMap((p) => p.organisations || [])
                  .map((o) => [o.id, o])
              ).values()].map((org) => (
                <a href={`/organisations/${org.slug}`} class="group flex items-center gap-4 p-5 rounded-xl bg-white border border-gray-100 hover:shadow-lg transition-shadow">
                  {org.logo ? (
                    <div class="w-16 h-16 rounded-xl bg-white flex items-center justify-center flex-shrink-0 border border-gray-100 shadow-md p-2">
                      <img
                        src={buildImageUrl(org.logo.url)}
                        alt={org.name}
                        class="w-full h-full object-contain"
                      />
                    </div>
                  ) : (
                    <div class="w-16 h-16 rounded-xl bg-wood/20 flex items-center justify-center flex-shrink-0">
                      <span class="text-xl font-bold text-wood">{org.name.charAt(0)}</span>
                    </div>
                  )}
                  <div class="min-w-0">
                    <h3 class="font-semibold text-gray-900 group-hover:text-primary transition-colors truncate">{org.name}</h3>
                    {org.description && (
                      <p class="text-sm text-muted line-clamp-2">{org.description}</p>
                    )}
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Partenaires -->
  {edition.partenaires && edition.partenaires.length > 0 && (
    <section class="py-16 md:py-24 bg-surface">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-10">Partenaires</h2>
        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
          {edition.partenaires.map((partenaire) => {
            const org = partenaire.organisation;
            return (
              <a
                href={org ? `/organisations/${org.slug}` : "#"}
                class="flex items-center justify-center h-16 opacity-80 hover:opacity-100 transition-opacity"
                title={org?.name || ''}
              >
                {org?.logo ? (
                  <img
                    src={buildImageUrl(org.logo.url)}
                    alt={org.name}
                    class="h-full w-auto object-contain"
                  />
                ) : (
                  <span class="text-sm font-medium text-muted">{org?.name || ''}</span>
                )}
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Retours post-event -->
  {edition.edition_status === "passee" && (edition.summary || edition.gallery?.length > 0 || edition.video_urls || edition.testimonials) && (
    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-10">Retour sur l'événement</h2>
        {edition.summary && (
          <div class="prose prose-lg max-w-none mb-12" set:html={edition.summary} />
        )}
        {edition.testimonials && (
          <div class="mb-12">
            <h3 class="font-semibold text-gray-900 mb-6">Témoignages</h3>
            <div class="relative bg-gradient-to-br from-wood/5 to-gold/5 rounded-2xl p-8 md:p-10 border border-wood/10">
              <!-- Quote icon -->
              <svg class="absolute top-6 left-6 w-10 h-10 text-gold/30" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z"/>
              </svg>
              <div class="relative prose prose-sm max-w-none text-muted pl-4 md:pl-8" set:html={edition.testimonials} />
            </div>
          </div>
        )}
        {edition.video_urls && (
          <div class="mb-12">
            <h3 class="font-semibold text-gray-900 mb-4">Vidéos</h3>
            <div class="grid md:grid-cols-2 gap-6">
              {edition.video_urls.split('\n').filter((url: string) => url.trim()).map((url: string) => {
                const trimmed = url.trim();
                const youtubeMatch = trimmed.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]+)/);
                if (youtubeMatch) {
                  const videoId = youtubeMatch[1];
                  const watchUrl = `https://www.youtube.com/watch?v=${videoId}`;
                  const thumbnailUrl = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
                  return (
                    <a href={watchUrl} target="_blank" rel="noopener" class="group relative aspect-video rounded-xl overflow-hidden bg-gray-100 block">
                      <img src={thumbnailUrl} alt="Vidéo de l'événement" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                      <div class="absolute inset-0 bg-black/30 group-hover:bg-black/40 transition-colors flex items-center justify-center">
                        <div class="w-16 h-16 rounded-full bg-red-600 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                          <svg class="w-7 h-7 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M8 5v14l11-7z"/>
                          </svg>
                        </div>
                      </div>
                    </a>
                  );
                }
                return (
                  <a href={trimmed} target="_blank" rel="noopener" class="flex items-center gap-2 text-primary hover:text-primary-dark text-sm font-medium">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Voir la vidéo
                  </a>
                );
              })}
            </div>
          </div>
        )}
        {edition.gallery?.length > 0 && (
          <div>
            <h3 class="font-semibold text-gray-900 mb-4">Galerie photos</h3>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
              {edition.gallery.map((img) => (
                <img
                  src={buildImageUrl(img.url)}
                  alt={img.alternativeText || edition.title}
                  class="rounded-lg object-cover aspect-video w-full"
                />
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Share + CTA -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <!-- Share buttons -->
      <p class="text-sm text-muted mb-4">Partagez cette édition</p>
      <div class="flex items-center justify-center gap-3 mb-8">
        <a
          href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://journees-innovation-bois.fr/editions/${edition.slug}`)}`}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-4 py-2 bg-[#0A66C2] hover:bg-[#004182] text-white text-sm font-medium rounded-lg transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a
          href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(`https://journees-innovation-bois.fr/editions/${edition.slug}`)}&text=${encodeURIComponent(`${edition.title} — Journée de l'Innovation Filière Bois`)}`}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-4 py-2 bg-gray-800 hover:bg-gray-900 text-white text-sm font-medium rounded-lg transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          X / Twitter
        </a>
        <button
          onclick="navigator.clipboard.writeText(window.location.href).then(() => this.textContent = 'Copié !')"
          class="inline-flex items-center gap-2 px-4 py-2 border border-gray-200 hover:border-gray-300 text-gray-700 text-sm font-medium rounded-lg transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/>
          </svg>
          Copier le lien
        </button>
      </div>

      <a href="/editions" class="text-sm font-medium text-primary hover:text-primary-dark transition-colors">
        &larr; Retour aux éditions
      </a>
    </div>
  </section>
</Layout>
