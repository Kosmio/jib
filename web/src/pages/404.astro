---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page non trouvée">
  <div class="min-h-[70vh] flex items-center justify-center bg-surface px-6">
    <div class="text-center">
      <p class="text-7xl font-bold text-primary mb-4">404</p>
      <h1 class="text-2xl font-semibold text-gray-900 mb-3">Page introuvable</h1>
      <p class="text-muted mb-8 max-w-md mx-auto">
        La page que vous recherchez n'existe pas ou a été déplacée.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary-dark text-white font-semibold text-sm rounded-lg transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
        </svg>
        Retour à l'accueil
      </a>
    </div>
  </div>
</Layout>
