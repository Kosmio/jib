---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import { getStaticPageBySlug } from "../lib/strapi";
import { marked } from "marked";

const page = await getStaticPageBySlug("confidentialite");

const title = page?.title ?? "Politique de confidentialité";
const subtitle = page?.hero_subtitle || undefined;
const description = page?.meta_description ?? "Politique de confidentialité et protection des données personnelles.";
const html = page?.body ? marked.parse(page.body) : null;
---

<Layout title={`${title} — Journées de l'Innovation Filière Bois`} description={description}>
  <Hero title={title} subtitle={subtitle} compact />

  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose prose-lg max-w-none text-muted">
      {html ? <Fragment set:html={html} /> : (
        <>
          <h2>Responsable du traitement</h2>
          <p>
            <strong>Xylofutur</strong> — Site de Pierroton, 69 route d'Arcachon, 33612 Cestas Cedex<br />
            Email : <a href="mailto:contact@xylofutur.fr">contact@xylofutur.fr</a>
          </p>
          <p>
            Pour exercer vos droits RGPD, contactez-nous à : <a href="mailto:contact@xylofutur.fr">contact@xylofutur.fr</a>
          </p>
        </>
      )}
    </div>
  </section>
</Layout>
