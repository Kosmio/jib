---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import { getStaticPageBySlug } from "../lib/strapi";
import { marked } from "marked";

const page = await getStaticPageBySlug("mentions-legales");

const title = page?.title ?? "Mentions légales";
const subtitle = page?.hero_subtitle || undefined;
const description = page?.meta_description ?? "Mentions légales du site des Journées de l'Innovation de la Filière Bois.";
const html = page?.body ? marked.parse(page.body) : null;
---

<Layout title={`${title} — Journées de l'Innovation Filière Bois`} description={description}>
  <Hero title={title} subtitle={subtitle} compact />

  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose prose-lg max-w-none text-muted">
      {html ? <Fragment set:html={html} /> : (
        <>
          <h2>Éditeur du site</h2>
          <p>
            <strong>Xylofutur — Pôle de Compétitivité Produits et Matériaux des Forêts Cultivées</strong><br />
            Siège social : Xylofutur, Site de Pierroton, 69 route d'Arcachon, 33612 Cestas Cedex<br />
            Téléphone : 05 56 81 52 90<br />
            Email : <a href="mailto:contact@xylofutur.fr">contact@xylofutur.fr</a>
          </p>
          <p>
            Directrice de la publication : Charlotte Perrier, Directrice du Pôle Xylofutur.
          </p>
          <h2>Crédits</h2>
          <p>Conception et développement : <a href="https://kosmio.fr" target="_blank" rel="noopener">Kosmio</a></p>
        </>
      )}
    </div>
  </section>
</Layout>
