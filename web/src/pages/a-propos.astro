---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
---

<Layout title="Qui sommes-nous — Journées de l'Innovation Filière Bois" description="Découvrez les organisations à l'origine des Journées de l'Innovation de la Filière Bois : Xylofutur, Fibois, CODIFAB et leurs partenaires.">
  <Hero
    title="Qui sommes-nous ?"
    subtitle="Les organisations porteuses des Journées de l'Innovation de la Filière Bois."
    compact
  />

  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="prose prose-lg max-w-none">
        <p class="text-lg text-muted leading-relaxed">
          Les Journées de l'Innovation de la Filière Bois sont portées par une coalition d'acteurs engagés pour accélérer l'innovation dans la filière forêt-bois française.
        </p>
      </div>

      <div class="mt-16 space-y-12">
        <!-- Xylofutur -->
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <div class="w-48 flex-shrink-0 flex items-center justify-center">
            <img src="/assets/logo-xylo.png" alt="Xylofutur" class="h-20 object-contain" />
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900">Xylofutur</h3>
            <p class="mt-1 text-sm font-medium text-primary">Pôle de Compétitivité de la filière forêt-bois</p>
            <p class="mt-3 text-muted leading-relaxed">
              Xylofutur accompagne les acteurs de son écosystème dans leurs projets d'innovation. À ce titre, il s'associe avec les interprofessions Fibois régionales pour organiser les Journées de l'Innovation en régions (2026-2028), avec le soutien du CODIFAB.
            </p>
            <a href="https://xylofutur.fr" target="_blank" rel="noopener" class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-primary hover:text-primary-dark transition-colors">
              xylofutur.fr
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        </div>

        <hr class="border-gray-100" />

        <!-- Fibois -->
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <div class="w-48 flex-shrink-0 flex items-center justify-center">
            <div class="w-20 h-20 rounded-full bg-primary/10 flex items-center justify-center">
              <span class="text-2xl font-bold text-primary">F</span>
            </div>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900">Fibois</h3>
            <p class="mt-1 text-sm font-medium text-primary">Interprofessions régionales de la filière forêt-bois</p>
            <p class="mt-3 text-muted leading-relaxed">
              Les Fibois sont les associations interprofessionnelles de la filière forêt-bois en régions. Elles réunissent les acteurs de la filière dans un réseau professionnel soutenu par les partenaires publics. Chaque édition régionale est co-organisée avec le Fibois local.
            </p>
          </div>
        </div>

        <hr class="border-gray-100" />

        <!-- CODIFAB -->
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <div class="w-48 flex-shrink-0 flex items-center justify-center">
            <div class="w-20 h-20 rounded-full bg-accent/10 flex items-center justify-center">
              <span class="text-2xl font-bold text-accent-dark">C</span>
            </div>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900">CODIFAB</h3>
            <p class="mt-1 text-sm font-medium text-primary">Développement des Industries Françaises de l'Ameublement et du Bois</p>
            <p class="mt-3 text-muted leading-relaxed">
              Le CODIFAB soutient financièrement les Journées de l'Innovation, contribuant au développement et à la structuration de l'innovation au sein de la filière bois française.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Équipe -->
  <section class="py-16 md:py-24 bg-surface">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-10">L'équipe Xylofutur</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        {[
          { name: "Charlotte Perrier", role: "Directrice du pôle", email: "charlotte.perrier@xylofutur.fr", phone: "06 51 26 80 20" },
          { name: "Apolline Oswald", role: "Responsable Équipe Projet", email: "apolline.oswald@xylofutur.fr", phone: "06 41 33 27 22" },
          { name: "Damien Alonso", role: "Chargé de communication", email: "damien.alonso@xylofutur.fr", phone: "06 02 46 24 90" },
          { name: "Lucas De Pedro", role: "Chef de Projets Innovation", email: "lucas.depedro@xylofutur.fr", phone: "07 88 353 363" },
          { name: "Claudia Antoniotti", role: "Chargée de Mission Europe", email: "claudia.antoniotti@xylofutur.fr", phone: "07 81 89 09 60" },
          { name: "Abdelwahab Bessaad", role: "Chef de Projets Arbre et Forêt", email: "abdelwahab.bessaad@xylofutur.fr", phone: "07 67 32 40 57" },
          { name: "Netih Demba", role: "Chargée de mission StartUps", email: "netih.demba@xylofutur.fr", phone: "07 50 06 17 74" },
        ].map((member) => (
          <div class="bg-white rounded-xl p-5 border border-gray-100">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                <span class="text-sm font-bold text-primary">{member.name.split(" ").map((n) => n[0]).join("")}</span>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 text-sm">{member.name}</h3>
                <p class="text-xs text-muted">{member.role}</p>
              </div>
            </div>
            <div class="mt-3 flex flex-col gap-1 text-xs text-muted">
              <a href={`mailto:${member.email}`} class="hover:text-primary transition-colors">{member.email}</a>
              <span>{member.phone}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
