---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import EditionBadges from "../components/EditionBadges.astro";
import { getPartenaires, getIntervenants, buildImageUrl } from "../lib/strapi";
import type { Edition, Intervenant } from "../lib/types";

let partenaires = { data: [] } as Awaited<ReturnType<typeof getPartenaires>>;
try {
  partenaires = await getPartenaires();
} catch {}

let intervenants = { data: [] } as Awaited<ReturnType<typeof getIntervenants>>;
try {
  intervenants = await getIntervenants();
} catch {}

const roleLabels: Record<string, string> = {
  "soutien": "Soutien national",
  "co-organisateur": "Co-organisateurs",
  "institutionnel": "Partenaires institutionnels",
  "prive": "Entreprises partenaires",
};

const roleOrder = ["soutien", "co-organisateur", "institutionnel", "prive"];

const grouped = roleOrder.reduce((acc, role) => {
  const items = partenaires?.data?.filter((p) => p.role === role) || [];
  if (items.length > 0) acc.push({ role, label: roleLabels[role] || role, items });
  return acc;
}, [] as { role: string; label: string; items: typeof partenaires.data }[]);

// --- Intervenants : on regroupe par ORGANISATION et on agrège leurs éditions ---
const upcomingStatuses = new Set(["a-venir", "inscriptions-ouvertes", "complet"]);

const editionsForIntervenant = (intervenant: Intervenant): Edition[] => {
  const items = intervenant.programme_items ?? [];
  const map = new Map<string, Edition>();
  for (const it of items) {
    if (it?.edition?.documentId) map.set(it.edition.documentId, it.edition);
  }
  return Array.from(map.values());
};

type OrgGroup = {
  documentId: string;
  name: string;
  slug: string | null;
  logoUrl: string | null;
  editions: Edition[];
};

const orgsMap = new Map<string, OrgGroup>();
for (const intervenant of intervenants?.data ?? []) {
  const org = intervenant.organisation;
  if (!org?.documentId) continue;
  const eds = editionsForIntervenant(intervenant);
  if (eds.length === 0) continue;
  let group = orgsMap.get(org.documentId);
  if (!group) {
    group = {
      documentId: org.documentId,
      name: org.name,
      slug: org.slug ?? null,
      logoUrl: org.logo?.url ?? null,
      editions: [],
    };
    orgsMap.set(org.documentId, group);
  }
  const seen = new Set(group.editions.map((e) => e.documentId));
  for (const e of eds) {
    if (!seen.has(e.documentId)) {
      group.editions.push(e);
      seen.add(e.documentId);
    }
  }
}

const orgSortKey = (g: OrgGroup): number => {
  if (g.editions.length === 0) return Number.POSITIVE_INFINITY;
  const upcoming = g.editions
    .filter((e) => upcomingStatuses.has(e.edition_status))
    .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
  if (upcoming.length > 0) return new Date(upcoming[0].date).getTime();
  const passees = g.editions
    .filter((e) => e.edition_status === "passee")
    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
  if (passees.length > 0) return -new Date(passees[0].date).getTime();
  return Number.POSITIVE_INFINITY;
};

const intervenantOrganisations = Array.from(orgsMap.values())
  .sort((a, b) => orgSortKey(a) - orgSortKey(b));
---

<Layout title="Nos partenaires & intervenants — Journées de l'Innovation Filière Bois" description="Découvrez les partenaires et intervenants des Journées de l'Innovation de la Filière Bois : soutiens nationaux, co-organisateurs, institutionnels et entreprises qui prennent la parole.">
  <Hero
    title="Nos partenaires"
    subtitle="Une dynamique collective pour accompagner l'innovation dans la filière bois."
    compact
  />

  <!-- ============================ -->
  <!-- Section Partenaires           -->
  <!-- ============================ -->
  <section id="partenaires" class="py-16 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold">Nos partenaires</h2>
        <p class="mt-3 text-muted max-w-2xl mx-auto">
          Les organisations qui soutiennent et co-construisent les Journées de l'Innovation Filière Bois.
        </p>
      </div>

      {grouped.length > 0 ? (
        <div class="space-y-16">
          {grouped.map(({ label, items }) => (
            <div>
              <h3 class="text-xl font-bold mb-8">{label}</h3>
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {items.map((partenaire) => {
                  const org = partenaire.organisation;
                  const eds = (partenaire.editions ?? []) as Edition[];
                  return (
                    <a
                      href={org ? `/organisations/${org.slug}` : "#"}
                      class="flex flex-col items-center text-center p-6 rounded-xl bg-surface border border-gray-100 hover:shadow-md transition-shadow group"
                    >
                      {org?.logo ? (
                        <img
                          src={buildImageUrl(org.logo.url)}
                          alt={org.name}
                          class="h-16 object-contain mb-4"
                        />
                      ) : (
                        <div class="h-16 flex items-center justify-center mb-4">
                          <span class="text-lg font-bold text-primary/30">{org?.name || ''}</span>
                        </div>
                      )}
                      <h4 class="font-semibold text-sm">{org?.name || ''}</h4>
                      {org?.description && (
                        <p class="mt-2 text-xs text-muted leading-relaxed">{org.description}</p>
                      )}
                      {eds.length > 0 && (
                        <div class="mt-3 w-full">
                          <EditionBadges editions={eds} />
                        </div>
                      )}
                      {org?.website && (
                        <span
                          class="mt-3 inline-flex items-center gap-1.5 text-xs font-medium text-primary-dark hover:text-primary transition-colors"
                          onclick={`event.preventDefault(); event.stopPropagation(); window.open('${org.website}', '_blank');`}
                        >
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                          </svg>
                          Site web
                        </span>
                      )}
                      {org?.linkedin_url && (
                        <span
                          class="mt-3 inline-flex items-center gap-1.5 text-xs font-medium text-[#0A66C2] hover:text-[#004182] transition-colors"
                          onclick={`event.preventDefault(); event.stopPropagation(); window.open('${org.linkedin_url}', '_blank');`}
                        >
                          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                          </svg>
                          LinkedIn
                        </span>
                      )}
                    </a>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-muted text-lg">Les partenaires seront bientôt présentés.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ============================ -->
  <!-- Section Intervenants          -->
  <!-- ============================ -->
  <section id="intervenants" class="py-16 md:py-24 bg-surface">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold">Les intervenants</h2>
        <p class="mt-3 text-muted max-w-2xl mx-auto">
          Les organisations qui prennent la parole lors des Journées de l'Innovation.
        </p>
      </div>

      {intervenantOrganisations.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {intervenantOrganisations.map((g) => (
            <a
              href={g.slug ? `/organisations/${g.slug}` : "#"}
              class="flex flex-col items-center text-center p-6 rounded-xl bg-white border border-gray-100 hover:shadow-md transition-shadow group"
            >
              {g.logoUrl ? (
                <img
                  src={buildImageUrl(g.logoUrl)}
                  alt={g.name}
                  class="h-16 object-contain mb-4"
                />
              ) : (
                <div class="h-16 flex items-center justify-center mb-4">
                  <span class="text-lg font-bold text-primary/30">{g.name}</span>
                </div>
              )}
              <h3 class="font-semibold text-sm group-hover:text-primary transition-colors">
                {g.name}
              </h3>
              <div class="mt-3 w-full">
                <EditionBadges editions={g.editions} />
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-muted text-lg">Les organisations intervenantes seront bientôt présentées.</p>
        </div>
      )}
    </div>
  </section>
</Layout>
