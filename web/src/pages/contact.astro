---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ContactForm from "../react-components/ContactForm";

const strapiUrl = import.meta.env.REACT_STRAPI_URL || import.meta.env.STRAPI_URL || "";
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || "";
---

<Layout title="Contact" description="Contactez-nous">
  <Hero
    title="Contactez-nous"
    subtitle={["Une question ? Un projet ? N'hésitez pas à nous écrire."]}
    bgHeight="h-[350px] md:h-[400px]"
    paddingT="md:pt-[180px] pt-[114px]"
  />

  <div id="content" class="bg-white py-16 md:py-24 px-5 md:px-[80px]">
    <ContactForm client:visible strapiUrl={strapiUrl} recaptchaSiteKey={recaptchaSiteKey} />
  </div>
</Layout>
