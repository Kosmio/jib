---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Card from "../components/Card.astro";
import { getArticles, buildImageUrl } from "../lib/strapi";

const articles = await getArticles({ limit: 3, start: 0 });
---

<Layout title="Skelly — Astro + Strapi" description="Un projet starter moderne pour démarrer rapidement vos applications web">
  <!-- Hero with mascot -->
  <section class="relative bg-gradient-to-br from-primary-dark via-primary to-primary-light pt-36 pb-24 md:pt-44 md:pb-32 overflow-hidden">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-50"></div>
    <div class="relative max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center gap-10 md:gap-16">
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
          Construisez plus vite, lancez plus tôt
        </h1>
        <p class="mt-4 text-lg md:text-xl text-blue-100 max-w-xl">
          Un starter complet avec CMS, formulaire de contact, newsletter et déploiement Docker. Prêt à personnaliser.
        </p>
        <div class="mt-8">
          <a
            href="/articles"
            class="inline-flex items-center gap-2 px-8 py-3.5 bg-accent hover:bg-accent-dark text-white font-semibold rounded-lg transition-colors shadow-lg shadow-accent/25"
          >
            Découvrir
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
      <div class="flex-shrink-0">
        <img
          src="/assets/skelly.png"
          alt="Skelly, la mascotte"
          class="w-48 md:w-64 lg:w-72 drop-shadow-2xl"
        />
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="content" class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
          Tout ce qu'il faut pour démarrer
        </h2>
        <p class="mt-4 text-muted text-lg max-w-2xl mx-auto">
          Ce starter regroupe les briques essentielles d'un projet web moderne, configurées et prêtes à l'emploi.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-xl bg-surface border border-gray-100">
          <div class="w-10 h-10 rounded-lg bg-blue-100 text-primary flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Strapi CMS</h3>
          <p class="text-sm text-muted leading-relaxed">Gestion de contenu headless avec API REST, types personnalisables et interface d'administration complète.</p>
        </div>

        <div class="p-6 rounded-xl bg-surface border border-gray-100">
          <div class="w-10 h-10 rounded-lg bg-orange-100 text-accent-dark flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Astro SSR</h3>
          <p class="text-sm text-muted leading-relaxed">Rendu côté serveur ultra-rapide avec hydratation sélective des composants React interactifs.</p>
        </div>

        <div class="p-6 rounded-xl bg-surface border border-gray-100">
          <div class="w-10 h-10 rounded-lg bg-purple-100 text-purple-600 flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Contact & Newsletter</h3>
          <p class="text-sm text-muted leading-relaxed">Formulaire de contact via Brevo, inscription newsletter avec protection anti-bot Altcha.</p>
        </div>

        <div class="p-6 rounded-xl bg-surface border border-gray-100">
          <div class="w-10 h-10 rounded-lg bg-green-100 text-green-600 flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">RGPD & Cookies</h3>
          <p class="text-sm text-muted leading-relaxed">Bannière de consentement configurable avec gestion des catégories de cookies et analytics conditionnel.</p>
        </div>

        <div class="p-6 rounded-xl bg-surface border border-gray-100">
          <div class="w-10 h-10 rounded-lg bg-cyan-100 text-cyan-600 flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Docker & CI/CD</h3>
          <p class="text-sm text-muted leading-relaxed">Dockerfiles multi-stage, overlays par environnement et script de déploiement unifié.</p>
        </div>

        <div class="p-6 rounded-xl bg-surface border border-gray-100">
          <div class="w-10 h-10 rounded-lg bg-pink-100 text-pink-600 flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Tailwind CSS</h3>
          <p class="text-sm text-muted leading-relaxed">Design system extensible avec thème personnalisable, typographie Inter et composants réutilisables.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest articles -->
  {articles?.data?.length > 0 && (
    <section class="py-20 md:py-28 bg-surface">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Derniers articles</h2>
            <p class="mt-3 text-muted">Les publications les plus récentes du blog.</p>
          </div>
          <a href="/articles" class="hidden sm:inline-flex items-center gap-1 text-sm font-medium text-primary hover:text-primary-dark transition-colors">
            Tout voir
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {articles.data.map((article) => (
            <Card
              title={article.title}
              text={article.excerpt}
              slug={article.slug}
              date={article.published_date
                ? new Date(article.published_date).toLocaleDateString("fr-FR", { year: "numeric", month: "long", day: "numeric" })
                : undefined}
              image={article.image ? buildImageUrl(article.image.url) : undefined}
            />
          ))}
        </div>

        <div class="mt-10 text-center sm:hidden">
          <a href="/articles" class="inline-flex items-center gap-1 text-sm font-medium text-primary">
            Voir tous les articles
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Un projet en tête ?</h2>
      <p class="mt-4 text-muted text-lg">
        Utilisez ce starter comme base, personnalisez-le à votre image et lancez votre projet en quelques heures.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center px-7 py-3 bg-primary hover:bg-primary-dark text-white font-semibold text-sm rounded-lg transition-colors shadow-sm">
          Nous contacter
        </a>
        <a href="/articles" class="inline-flex items-center justify-center px-7 py-3 border-2 border-gray-200 text-gray-700 hover:border-gray-300 font-semibold text-sm rounded-lg transition-colors">
          Lire le blog
        </a>
      </div>
    </div>
  </section>
</Layout>
