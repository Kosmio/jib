        </a>
      </div>
    </div>
  </section>

  <!-- Partenaires — bandeau défilant -->
  <section class="py-12 bg-white border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-center text-sm font-medium text-muted mb-8 uppercase tracking-wider">Avec le soutien de</p>
