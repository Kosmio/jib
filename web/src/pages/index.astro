---
import Layout from "../layouts/Layout.astro";
import { getEditions, buildImageUrl } from "../lib/strapi";
import { regionLabels } from "../lib/types";

let editions = { data: [] } as Awaited<ReturnType<typeof getEditions>>;
try {
  editions = await getEditions();
} catch {}
const nextEdition = editions?.data?.find((e) => e.edition_status === "inscriptions-ouvertes" || e.edition_status === "a-venir");

// Mapping régions → coordonnées SVG sur la carte de France (viewBox 0 0 1280 720, offset +300px)
const regionCoords: Record<string, { x: number; y: number }> = {
  'hauts-de-france': { x: 940, y: 105 },
  'normandie': { x: 815, y: 195 },
  'bretagne': { x: 670, y: 245 },
  'pays-de-la-loire': { x: 740, y: 310 },
  'centre-val-de-loire': { x: 850, y: 310 },
  'ile-de-france': { x: 930, y: 220 },
  'grand-est': { x: 1100, y: 215 },
  'bourgogne-franche-comte': { x: 1030, y: 310 },
  'nouvelle-aquitaine': { x: 770, y: 440 },
  'auvergne-rhone-alpes': { x: 1010, y: 410 },
  'occitanie': { x: 870, y: 530 },
  'region-sud': { x: 1030, y: 530 },
  'corse': { x: 1150, y: 520 },
};

// Régions qui ont au moins une édition
const editionRegions = new Set(editions?.data?.map((e) => e.region) ?? []);

const statusLabels: Record<string, string> = {
  "a-venir": "À venir",
  "inscriptions-ouvertes": "Inscriptions ouvertes",
  "complet": "Complet",
  "passee": "Passée",
};

const statusColors: Record<string, string> = {
  "a-venir": "bg-white/20 text-white",
  "inscriptions-ouvertes": "bg-accent text-white",
  "complet": "bg-white/20 text-white",
  "passee": "bg-white/10 text-white/70",
};
---

<Layout title="Journées de l'Innovation Filière Bois" description="Site des Journées de l'Innovation de la Filière Bois — événements régionaux portés par Xylofutur et les Fibois">
  <!-- Hero -->
  <section class="relative min-h-[75vh] bg-wood overflow-hidden flex items-center">
    <!-- Wood texture overlay -->
    <div class="absolute inset-0 opacity-[0.08]" style="background-image: url('data:image/svg+xml;base64,');"></div>

    <!-- Network nodes SVG — France map shape (shifted right) -->
    <div class="absolute inset-0 overflow-hidden">
      <svg class="hero-network absolute inset-0 w-full h-full" viewBox="0 0 1280 720" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <!-- France outline (border connections) -->
        <g stroke="#F0AB00" stroke-width="1" opacity="0.16">
          <line x1="940" y1="105" x2="900" y2="85" class="hero-line hero-line-1" />
          <line x1="900" y1="85" x2="860" y2="150" class="hero-line hero-line-2" />
          <line x1="860" y1="150" x2="815" y2="195" class="hero-line hero-line-3" />
          <line x1="815" y1="195" x2="670" y2="245" class="hero-line hero-line-4" />
          <line x1="670" y1="245" x2="700" y2="275" class="hero-line hero-line-5" />
          <line x1="700" y1="275" x2="740" y2="310" class="hero-line hero-line-6" />
          <line x1="740" y1="310" x2="720" y2="370" class="hero-line hero-line-7" />
          <line x1="720" y1="370" x2="770" y2="440" class="hero-line hero-line-8" />
          <line x1="770" y1="440" x2="750" y2="500" class="hero-line hero-line-9" />
          <line x1="750" y1="500" x2="780" y2="560" class="hero-line hero-line-10" />
          <line x1="780" y1="560" x2="870" y2="530" class="hero-line hero-line-11" />
          <line x1="870" y1="530" x2="920" y2="590" class="hero-line hero-line-1" />
          <line x1="920" y1="590" x2="970" y2="570" class="hero-line hero-line-2" />
          <line x1="970" y1="570" x2="1030" y2="530" class="hero-line hero-line-3" />
          <line x1="1030" y1="530" x2="1080" y2="490" class="hero-line hero-line-4" />
          <line x1="1080" y1="490" x2="1060" y2="435" class="hero-line hero-line-5" />
          <line x1="1060" y1="435" x2="1085" y2="360" class="hero-line hero-line-6" />
          <line x1="1085" y1="360" x2="1050" y2="290" class="hero-line hero-line-7" />
          <line x1="1050" y1="290" x2="1100" y2="215" class="hero-line hero-line-8" />
          <line x1="1100" y1="215" x2="1080" y2="160" class="hero-line hero-line-9" />
          <line x1="1080" y1="160" x2="1000" y2="130" class="hero-line hero-line-10" />
          <line x1="1000" y1="130" x2="940" y2="105" class="hero-line hero-line-11" />
        </g>
        <!-- Interior network connections -->
        <g stroke="#F0AB00" stroke-width="0.6" opacity="0.10">
          <!-- Paris hub connections -->
          <line x1="930" y1="220" x2="940" y2="105" class="hero-line hero-line-1" />
          <line x1="930" y1="220" x2="815" y2="195" class="hero-line hero-line-2" />
          <line x1="930" y1="220" x2="1100" y2="215" class="hero-line hero-line-3" />
          <line x1="930" y1="220" x2="850" y2="310" class="hero-line hero-line-4" />
          <line x1="930" y1="220" x2="1030" y2="310" class="hero-line hero-line-5" />
          <line x1="930" y1="220" x2="1010" y2="410" class="hero-line hero-line-6" />
          <!-- Regional connections -->
          <line x1="670" y1="245" x2="740" y2="310" class="hero-line hero-line-7" />
          <line x1="740" y1="310" x2="850" y2="310" class="hero-line hero-line-8" />
          <line x1="850" y1="310" x2="1030" y2="310" class="hero-line hero-line-9" />
          <line x1="770" y1="440" x2="870" y2="530" class="hero-line hero-line-10" />
          <line x1="870" y1="530" x2="1030" y2="530" class="hero-line hero-line-11" />
          <line x1="1010" y1="410" x2="1030" y2="530" class="hero-line hero-line-1" />
          <line x1="1010" y1="410" x2="1030" y2="310" class="hero-line hero-line-2" />
          <line x1="1010" y1="410" x2="870" y2="530" class="hero-line hero-line-3" />
          <line x1="770" y1="440" x2="1010" y2="410" class="hero-line hero-line-4" />
          <line x1="740" y1="310" x2="770" y2="440" class="hero-line hero-line-5" />
          <line x1="850" y1="310" x2="770" y2="440" class="hero-line hero-line-6" />
          <line x1="1100" y1="215" x2="1030" y2="310" class="hero-line hero-line-7" />
          <line x1="1030" y1="310" x2="1060" y2="435" class="hero-line hero-line-8" />
          <!-- Extra minor connections -->
          <line x1="815" y1="195" x2="740" y2="310" class="hero-line hero-line-9" />
          <line x1="850" y1="310" x2="1010" y2="410" class="hero-line hero-line-10" />
          <line x1="670" y1="245" x2="815" y2="195" class="hero-line hero-line-11" />
        </g>

        <!-- Decorative dots — small, static, scattered across France -->
        <g fill="#F0AB00">
          <!-- Outline border dots -->
          <circle cx="900" cy="85" r="1.5" opacity="0.2" class="hero-node" />
          <circle cx="860" cy="150" r="1.5" opacity="0.2" class="hero-node" />
          <circle cx="700" cy="275" r="1.5" opacity="0.2" class="hero-node" />
          <circle cx="720" cy="370" r="1.5" opacity="0.18" class="hero-node" />
          <circle cx="750" cy="500" r="1.5" opacity="0.18" class="hero-node" />
          <circle cx="780" cy="560" r="1.5" opacity="0.18" class="hero-node" />
          <circle cx="920" cy="590" r="1.5" opacity="0.2" class="hero-node" />
          <circle cx="970" cy="570" r="1.5" opacity="0.2" class="hero-node" />
          <circle cx="1080" cy="490" r="1.5" opacity="0.18" class="hero-node" />
          <circle cx="1085" cy="360" r="1.5" opacity="0.18" class="hero-node" />
          <circle cx="1050" cy="290" r="1.5" opacity="0.2" class="hero-node" />
          <circle cx="1080" cy="160" r="1.5" opacity="0.2" class="hero-node" />
          <circle cx="1000" cy="130" r="1.5" opacity="0.2" class="hero-node" />
          <!-- Interior scattered dots — small towns -->
          <circle cx="880" cy="130" r="1" opacity="0.15" class="hero-node" />
          <circle cx="960" cy="155" r="1" opacity="0.15" class="hero-node" />
          <circle cx="780" cy="220" r="1" opacity="0.12" class="hero-node" />
          <circle cx="870" cy="240" r="1" opacity="0.15" class="hero-node" />
          <circle cx="990" cy="180" r="1" opacity="0.12" class="hero-node" />
          <circle cx="1040" cy="230" r="1" opacity="0.12" class="hero-node" />
          <circle cx="1070" cy="270" r="1" opacity="0.12" class="hero-node" />
          <circle cx="980" cy="270" r="1" opacity="0.12" class="hero-node" />
          <circle cx="900" cy="290" r="1" opacity="0.12" class="hero-node" />
          <circle cx="790" cy="280" r="1" opacity="0.12" class="hero-node" />
          <circle cx="710" cy="330" r="1" opacity="0.12" class="hero-node" />
          <circle cx="800" cy="360" r="1" opacity="0.12" class="hero-node" />
          <circle cx="880" cy="350" r="1" opacity="0.12" class="hero-node" />
          <circle cx="950" cy="340" r="1" opacity="0.12" class="hero-node" />
          <circle cx="1060" cy="340" r="1" opacity="0.12" class="hero-node" />
          <circle cx="960" cy="450" r="1" opacity="0.12" class="hero-node" />
          <circle cx="830" cy="470" r="1" opacity="0.12" class="hero-node" />
          <circle cx="900" cy="480" r="1" opacity="0.12" class="hero-node" />
          <circle cx="1040" cy="460" r="1" opacity="0.12" class="hero-node" />
          <circle cx="790" cy="520" r="1" opacity="0.12" class="hero-node" />
          <circle cx="930" cy="540" r="1" opacity="0.12" class="hero-node" />
          <circle cx="980" cy="500" r="1" opacity="0.12" class="hero-node" />
          <circle cx="1060" cy="510" r="1" opacity="0.12" class="hero-node" />
          <circle cx="850" cy="420" r="1" opacity="0.12" class="hero-node" />
          <circle cx="760" cy="390" r="1" opacity="0.12" class="hero-node" />
          <circle cx="920" cy="370" r="1" opacity="0.12" class="hero-node" />
        </g>

        <!-- Regional capital nodes — edition cities pulse, others static -->
        <g fill="#F0AB00">
          {Object.entries(regionCoords).map(([region, coords], i) => {
            const hasEdition = editionRegions.has(region);
            const r = hasEdition ? 3.5 : 2;
            const opacity = hasEdition ? 0.6 : 0.25;
            const cls = hasEdition
              ? `hero-node hero-node-edition hero-node-edition-${(i % 5) + 1}`
              : 'hero-node';
            return (
              <circle
                cx={coords.x}
                cy={coords.y}
                r={r}
                opacity={opacity}
                class={cls}
              />
            );
          })}
        </g>
      </svg>
    </div>

    <!-- Radial gradient overlay -->
    <div class="absolute inset-0" style="background: radial-gradient(circle at 60% 50%, rgba(240,171,0,0.12), transparent 50%);"></div>

    <!-- Content -->
    <div class="relative w-full max-w-[1280px] mx-auto px-6 md:px-16 pt-28 pb-16 md:pt-32 md:pb-20">
      <div class="flex flex-col lg:flex-row items-center lg:items-start gap-10 lg:gap-16">
      <div class="max-w-3xl mx-auto lg:mx-0 text-center lg:text-left flex-1">

        <!-- Logo JIB blanc -->
        <img src="/assets/logo-jib-blanc.svg" alt="Journées de l'Innovation Filière Bois" class="h-16 md:h-20 lg:h-24 mb-6 mx-auto lg:mx-0" />

        <h1 class="sr-only">La Journée de l'Innovation de la Filière Bois</h1>

          <!-- Subtitle -->
          <p class="mt-6 text-lg md:text-xl text-white/80 max-w-[520px] mx-auto lg:mx-0 leading-relaxed">
            Une dynamique collective pour connecter les acteurs, structurer des projets et accélérer les innovations de la filière bois.
          </p>

          <!-- Date/Lieu card -->
          {nextEdition && (
            <div class="mt-8 inline-flex flex-col sm:flex-row items-start sm:items-center gap-3 sm:gap-4 border border-white/20 rounded-xl px-5 py-4 sm:px-6 backdrop-blur-sm bg-white/5">
              <div class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span class="text-base md:text-xl font-medium">
                  {regionLabels[nextEdition.region] || nextEdition.region}
                </span>
              </div>
              <div class="hidden sm:block w-px h-8 bg-white/20"></div>
              <div class="sm:hidden w-full h-px bg-white/15"></div>
              <div class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <span class="text-base md:text-xl font-medium capitalize">
                  {new Date(nextEdition.date).toLocaleDateString("fr-FR", { weekday: "long", day: "numeric", month: "long", year: "numeric" })}
                </span>
              </div>
            </div>
          )}

          <!-- CTAs -->
          <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            {nextEdition?.inscription_url && nextEdition.edition_status === "inscriptions-ouvertes" ? (
              <a
                href={nextEdition.inscription_url}
                target="_blank"
                rel="noopener"
                class="hero-cta inline-flex items-center justify-center gap-2 px-6 py-3 md:px-7 md:py-4 bg-gold hover:bg-gold-light text-wood-dark font-semibold text-base md:text-lg rounded-xl transition-all duration-200 shadow-lg shadow-gold/25"
              >
                S'inscrire à la journée
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            ) : (
              <a
                href="/editions"
                class="hero-cta inline-flex items-center justify-center gap-2 px-6 py-3 md:px-7 md:py-4 bg-gold hover:bg-gold-light text-wood-dark font-semibold text-base md:text-lg rounded-xl transition-all duration-200 shadow-lg shadow-gold/25"
              >
                Découvrir les éditions
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            )}
            {nextEdition && (
              <a
                href={`/editions/${nextEdition.slug}`}
                class="inline-flex items-center justify-center gap-2 px-6 py-3 md:px-7 md:py-4 border-2 border-white/25 hover:border-white/40 text-white font-medium text-base md:text-lg rounded-xl transition-all duration-200"
              >
                Découvrir le programme
              </a>
            )}
          </div>

          <!-- Social proof -->
          <div class="mt-10 flex flex-wrap items-center gap-6 justify-center lg:justify-start text-sm text-white/60">
            <div class="flex items-center gap-2">
              <span class="text-gold font-semibold text-base">150+</span> participants
            </div>
            <div class="w-1 h-1 rounded-full bg-white/30"></div>
            <div class="flex items-center gap-2">
              <span class="text-gold font-semibold text-base">12</span> pitchs innovation
            </div>
            <div class="w-1 h-1 rounded-full bg-white/30"></div>
            <div class="flex items-center gap-2">
              <span class="text-gold font-semibold text-base">8</span> financeurs présents
            </div>
          </div>
      </div>

      <!-- Image de la prochaine édition — cliquable -->
      {nextEdition?.image && (
        <a
          href={`/editions/${nextEdition.slug}`}
          class="hidden lg:block flex-shrink-0 group"
        >
          <div class="relative rounded-2xl overflow-hidden border-[3px] border-white/25 shadow-2xl max-w-sm transition-transform duration-300 group-hover:scale-[1.03]">
            <img
              src={buildImageUrl(nextEdition.image.url)}
              alt={nextEdition.title}
              class="w-full h-auto object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-wood-dark/40 to-transparent"></div>
          </div>
        </a>
      )}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </section>

  <!-- Pourquoi ces événements -->
  <section id="content" class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
          Pourquoi ces journées ?
        </h2>
        <p class="mt-4 text-muted text-lg max-w-2xl mx-auto">
          La filière forêt-bois fait face à des transformations majeures. Ces journées réunissent TPE, PME, startups, chercheurs et financeurs pour accélérer l'innovation.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-xl bg-surface border border-gray-100">
          <div class="w-10 h-10 rounded-lg bg-blue-100 text-blue-700 flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">IA & Digitalisation</h3>
          <p class="text-sm text-muted leading-relaxed">Comment l'intelligence artificielle et les outils numériques transforment les process de la filière bois.</p>
        </div>

        <div class="p-6 rounded-xl bg-surface border border-gray-100">
          <div class="w-10 h-10 rounded-lg bg-emerald-100 text-primary flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Economie circulaire</h3>
          <p class="text-sm text-muted leading-relaxed">Réemploi, recyclage, biosourcé — les modèles circulaires au service de la construction et de l'industrie bois.</p>
        </div>

        <div class="p-6 rounded-xl bg-surface border border-gray-100">
          <div class="w-10 h-10 rounded-lg bg-amber-100 text-amber-700 flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Financement de l'innovation</h3>
          <p class="text-sm text-muted leading-relaxed">BpiFrance, business angels, aides régionales — les dispositifs pour financer vos projets innovants.</p>
        </div>
      </div>

      <div class="mt-10 text-center">
        <a href="/pourquoi" class="text-sm font-medium text-primary hover:text-primary-dark transition-colors">
          En savoir plus &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Éditions -->
  {editions?.data?.length > 0 && (
    <section class="py-20 md:py-28 bg-surface">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Les éditions</h2>
            <p class="mt-3 text-muted">Retrouvez les Journées de l'Innovation, région par région.</p>
          </div>
          <a href="/editions" class="hidden sm:inline-flex items-center gap-1 text-sm font-medium text-primary hover:text-primary-dark transition-colors">
            Tout voir
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {editions.data.slice(0, 6).map((edition) => (
            <a href={`/editions/${edition.slug}`} class="group block rounded-xl border border-gray-100 bg-white overflow-hidden hover:shadow-lg transition-shadow">
              {edition.image ? (
                <div class="aspect-square bg-surface overflow-hidden">
                  <img
                    src={buildImageUrl(edition.image.url)}
                    alt={edition.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
              ) : (
                <div class="aspect-square bg-gradient-to-br from-primary/10 to-accent/10 flex items-center justify-center">
                  <span class="text-3xl font-bold text-primary/20">{regionLabels[edition.region] || edition.region}</span>
                </div>
              )}
              <div class="p-5">
                <h3 class="font-semibold text-gray-900 group-hover:text-primary transition-colors">{edition.title}</h3>
                <p class="mt-1 text-sm text-muted">
                  {new Date(edition.date).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })} — {edition.city}
                </p>
              </div>
            </a>
          ))}
        </div>

        <div class="mt-10 text-center sm:hidden">
          <a href="/editions" class="inline-flex items-center gap-1 text-sm font-medium text-primary">
            Voir toutes les éditions &rarr;
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Dynamique collective -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Une dynamique collective</h2>
