---
import Layout from "../../layouts/Layout.astro";
import { MarkdownContent } from "../../react-components/MarkdownContent";
import { buildImageUrl, getArticles, getArticleBySlug } from "../../lib/strapi";

const { slug } = Astro.params;
const articleResponse = await getArticleBySlug(slug);
const article = articleResponse?.data?.[0];

if (!article) {
  return Astro.redirect("/404");
}

const allArticles = await getArticles();

const publishDate = article.published_date
  ? new Date(article.published_date).toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : new Date(article.publishedAt).toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });

const image = article.image;

const otherArticles = allArticles?.data
  ?.filter((a) => a.documentId !== article.documentId)
  ?.slice(0, 3) || [];
---

<Layout title={article.title} description={article.excerpt}>
  <div class="bg-gray-light flex flex-col lg:px-[190px] md:px-16 px-5 md:pt-[140px] pt-[114px] md:pb-[160px] pb-16">
    <div class="flex flex-col mt-4 gap-8 text-primary">
      <h1 class="md:text-[38px] md:leading-[50px] text-2xl font-semibold">
        {article.title}
      </h1>
      {article.excerpt && (
        <p class="text-justify">{article.excerpt}</p>
      )}
      <span class="text-[#828EC9]">Publié le {publishDate}</span>
    </div>
  </div>

  <div class="flex flex-col lg:px-[190px] md:px-16 px-5 text-primary">
    {image && (
      <div class="sm:mt-[-80px] mt-[-20px] flex flex-col justify-center md:px-20">
        <img
          alt={image.alternativeText || article.title}
          src={buildImageUrl(image.url)}
        />
      </div>
    )}
    <div class="md:px-20 mt-16 text-justify">
      <MarkdownContent markdown={article.content || ""} />
    </div>
  </div>

  {otherArticles.length > 0 && (
    <div class="justify-center lg:px-[80px] px-5 md:pt-16 md:pb-[104px] py-16 text-primary bg-gray-light">
      <h2 class="text-[32px] leading-[48px] text-center font-semibold text-primary mb-10">
        D'autres articles
      </h2>
      <div class="flex flex-row flex-wrap gap-10 justify-center">
        {otherArticles.map((other) => (
          <a
            href={`/articles/${other.slug}`}
            class="group flex flex-col bg-white rounded-lg overflow-hidden shadow-md hover:shadow-lg transition-shadow max-w-sm w-full"
          >
            {other.image ? (
              <div class="h-48 overflow-hidden">
                <img
                  src={buildImageUrl(other.image.url)}
                  alt={other.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            ) : (
              <div class="h-48 bg-gray-100 flex items-center justify-center">
                <span class="text-gray-400 text-sm">No image</span>
              </div>
            )}
            <div class="p-5">
              <h3 class="text-lg font-semibold text-primary mb-2">{other.title}</h3>
              {other.excerpt && (
                <p class="text-sm text-gray-600 line-clamp-3">{other.excerpt}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  )}
</Layout>
