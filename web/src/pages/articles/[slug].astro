---
import Layout from "../../layouts/Layout.astro";
import { MarkdownContent } from "../../react-components/MarkdownContent";
import { buildImageUrl, getArticles, getArticleBySlug } from "../../lib/strapi";

const { slug } = Astro.params;
const articleResponse = await getArticleBySlug(slug);
const article = articleResponse?.data?.[0];

if (!article) {
  return Astro.redirect("/404");
}

const allArticles = await getArticles();

const publishDate = article.published_date
  ? new Date(article.published_date).toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : new Date(article.publishedAt).toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });

const image = article.image;

const otherArticles = allArticles?.data
  ?.filter((a) => a.documentId !== article.documentId)
  ?.slice(0, 3) || [];
---

<Layout title={article.title} description={article.excerpt}>
  <!-- Article header -->
  <section class="bg-gradient-to-br from-primary-dark via-primary to-primary-light pt-28 pb-16 md:pt-36 md:pb-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <time class="text-sm text-blue-200">{publishDate}</time>
      <h1 class="mt-3 text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight">
        {article.title}
      </h1>
      {article.excerpt && (
        <p class="mt-4 text-lg text-blue-100 max-w-2xl mx-auto">{article.excerpt}</p>
      )}
    </div>
  </section>

  <!-- Article content -->
  <article class="max-w-3xl mx-auto px-6">
    {image && (
      <div class="-mt-8 mb-12 rounded-xl overflow-hidden shadow-xl">
        <img
          alt={image.alternativeText || article.title}
          src={buildImageUrl(image.url)}
          class="w-full"
        />
      </div>
    )}

    <div class="py-12 prose prose-lg max-w-none">
      <MarkdownContent markdown={article.content || ""} />
    </div>
  </article>

  <!-- Related articles -->
  {otherArticles.length > 0 && (
    <section class="py-20 bg-surface">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">Autres articles</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {otherArticles.map((other) => (
            <a
              href={`/articles/${other.slug}`}
              class="group flex flex-col bg-white rounded-xl overflow-hidden border border-gray-100 hover:border-gray-200 hover:shadow-lg transition-all duration-300"
            >
              {other.image ? (
                <div class="aspect-[16/10] overflow-hidden bg-surface">
                  <img
                    src={buildImageUrl(other.image.url)}
                    alt={other.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
              ) : (
                <div class="aspect-[16/10] bg-gradient-to-br from-surface to-surface-alt flex items-center justify-center">
                  <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                  </svg>
                </div>
              )}
              <div class="p-5">
                <h3 class="font-semibold text-gray-900 mb-1 group-hover:text-primary transition-colors">{other.title}</h3>
                {other.excerpt && (
                  <p class="text-sm text-muted line-clamp-2">{other.excerpt}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
