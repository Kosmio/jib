---
export interface Props {
  title: string;
  subtitle?: string;
  ctaLink?: string;
  ctaText?: string;
  compact?: boolean;
}

const {
  title,
  subtitle,
  ctaLink,
  ctaText,
  compact = false,
} = Astro.props;
---

<section class={`relative bg-gradient-to-br from-primary-dark via-primary to-primary-light ${compact ? "pt-28 pb-16" : "pt-36 pb-24 md:pt-44 md:pb-32"}`}>
  <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-50"></div>
  <div class="relative max-w-4xl mx-auto px-6 text-center">
    <h1 class={`font-bold text-white leading-tight ${compact ? "text-3xl md:text-4xl" : "text-4xl md:text-5xl lg:text-6xl"}`}>
      {title}
    </h1>
    {subtitle && (
      <p class={`mt-4 text-blue-100 max-w-2xl mx-auto ${compact ? "text-base" : "text-lg md:text-xl"}`}>
        {subtitle}
      </p>
    )}
    {ctaLink && ctaText && (
      <div class="mt-8">
        <a
          href={ctaLink}
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-accent hover:bg-accent-dark text-white font-semibold rounded-lg transition-colors shadow-lg shadow-accent/25"
        >
          {ctaText}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
