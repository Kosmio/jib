---
export interface Props {
  title: string;
  subtitle?: string;
  ctaLink?: string;
  ctaText?: string;
  compact?: boolean;
}

const {
  title,
  subtitle,
  ctaLink,
  ctaText,
  compact = false,
} = Astro.props;
---

<section class={`relative bg-wood overflow-hidden ${compact ? "pt-28 pb-14" : "pt-36 pb-24 md:pt-44 md:pb-32"}`}>
  <!-- Wood texture -->
  <div class="absolute inset-0 opacity-[0.08]" style="background-image: url('data:image/svg+xml;base64,');"></div>

  <!-- Subtle radial glow -->
  <div class="absolute inset-0" style="background: radial-gradient(circle at 50% 50%, rgba(246,196,83,0.08), transparent 60%);"></div>

  <div class="relative max-w-4xl mx-auto px-6 text-center">
    <h1 class={`font-heading font-semibold text-white leading-tight ${compact ? "text-3xl md:text-4xl" : "text-4xl md:text-5xl lg:text-6xl"}`}>
      {title}
    </h1>
    {subtitle && (
      <p class={`mt-4 text-white/70 max-w-2xl mx-auto ${compact ? "text-base" : "text-lg md:text-xl"}`}>
        {subtitle}
      </p>
    )}
    {ctaLink && ctaText && (
      <div class="mt-8">
        <a
          href={ctaLink}
          class="hero-cta inline-flex items-center gap-2 px-6 py-3 md:px-7 md:py-3.5 bg-gold hover:bg-gold-light text-wood-dark font-semibold rounded-xl transition-all duration-200 shadow-lg shadow-gold/25"
        >
          {ctaText}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
