---
const strapiUrl = import.meta.env.REACT_STRAPI_URL || process.env.REACT_STRAPI_URL || import.meta.env.STRAPI_URL || process.env.STRAPI_URL || "";
const strapiPublicUrl = import.meta.env.REACT_STRAPI_URL || process.env.REACT_STRAPI_URL || "";
const cookieConsent = (import.meta.env.PUBLIC_COOKIE_CONSENT || process.env.PUBLIC_COOKIE_CONSENT) === "true";
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-6xl mx-auto px-6 pt-16 pb-8">
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <a href="/" class="block mb-4">
          <img src="/assets/logo-jib-blanc.svg" alt="Journées de l'Innovation Filière Bois" class="h-10 object-contain" />
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          Les Journées de l'Innovation de la Filière Bois — événements régionaux portés par Xylofutur et les Fibois.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Navigation</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Accueil</a></li>
          <li><a href="/editions" class="hover:text-white transition-colors">Les éditions</a></li>
          <li><a href="/pourquoi" class="hover:text-white transition-colors">Pourquoi ?</a></li>
          <li><a href="/partenaires" class="hover:text-white transition-colors">Partenaires</a></li>
          <li><a href="/a-propos" class="hover:text-white transition-colors">Qui sommes-nous ?</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Newsletter</h3>
        <p class="text-sm text-gray-400 mb-4">Soyez informé des prochaines éditions des Journées de l'Innovation.</p>

        <div id="nl-alert" class="mb-3">
          <div id="nl-success-alert" class="hidden text-sm bg-green-900/50 text-green-300 border border-green-700 px-3 py-2 rounded-lg">
            Merci pour votre inscription !
          </div>
          <div id="nl-error-alert" class="hidden text-sm bg-red-900/50 text-red-300 border border-red-700 px-3 py-2 rounded-lg">
            Une erreur est survenue, veuillez réessayer.
          </div>
        </div>

        <form id="newsletter-form">
          <div class="flex">
            <input
              type="email"
              name="email"
              placeholder="votre@email.com"
              required
              class="flex-1 px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-l-lg text-sm text-white placeholder-gray-500 focus:outline-none focus:border-primary-light"
            />
            <button
              type="submit"
              class="px-5 py-2.5 bg-primary-light hover:bg-primary text-white text-sm font-medium rounded-r-lg transition-colors"
            >
              OK
            </button>
          </div>
          <div class="mt-2">
            <altcha-widget
              challengeurl={`${strapiUrl}/api/captcha/challenge`}
              auto="onsubmit"
              hidefooter
              style="--altcha-max-width: 100%;"
            ></altcha-widget>
          </div>
        </form>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-gray-500">
      <p>&copy; {new Date().getFullYear()} Xylofutur. Tous droits réservés.</p>
      <div class="flex items-center gap-4 flex-wrap justify-center">
        <a href="/mentions-legales" class="hover:text-gray-300 transition-colors">Mentions légales</a>
        <a href="/confidentialite" class="hover:text-gray-300 transition-colors">Confidentialité</a>
        {cookieConsent && (
          <button type="button" data-cc="c-settings" class="hover:text-gray-300 transition-colors">
            Gestion des cookies
          </button>
        )}
        {strapiPublicUrl && (
          <a href={`${strapiPublicUrl}/admin`} target="_blank" rel="noopener" class="hover:text-gray-300 transition-colors">
            Administration
          </a>
        )}
      </div>
    </div>
  </div>
</footer>

<script>
  import 'altcha';
</script>

<script define:vars={{ strapiUrl }}>
  document.addEventListener('DOMContentLoaded', function() {
    const nlSuccessAlert = document.querySelector('#nl-success-alert');
    const nlErrorAlert = document.querySelector('#nl-error-alert');

    document.querySelector('#newsletter-form').addEventListener('submit', function(event) {
      event.preventDefault();
      nlSuccessAlert.classList.add('hidden');
      nlErrorAlert.classList.add('hidden');

      var form = document.querySelector('#newsletter-form');
      var formData = new FormData(form);

      fetch(strapiUrl + '/api/newsletter/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: formData.get('email'),
          captchaToken: formData.get('altcha'),
        }),
      }).then(function(res) {
        if (res.status === 200) {
          nlSuccessAlert.classList.remove('hidden');
          form.reset();
        } else {
          nlErrorAlert.classList.remove('hidden');
        }
      }).catch(function() {
        nlErrorAlert.classList.remove('hidden');
      });
    });
  });
</script>
