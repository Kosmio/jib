---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Accueil" },
  { href: "/contact", label: "Contact" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100">
  <nav class="max-w-6xl mx-auto flex items-center justify-between px-6 h-16">
    <a href="/" class="flex items-center gap-2 font-bold text-lg text-primary">
      <img src="/assets/logo-xylo.png" alt="Journées de l'Innovation Filière Bois" class="h-8 object-contain" />
      Journées Innovation Bois
    </a>

    <ul class="hidden md:flex items-center gap-8 text-sm font-medium">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "transition-colors",
              currentPath === href || (href !== "/" && currentPath.startsWith(href))
                ? "text-primary"
                : "text-gray-600 hover:text-primary",
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-600" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white px-6 pb-4">
    <ul class="flex flex-col gap-3 pt-3 text-sm font-medium">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "block py-1 transition-colors",
              currentPath === href || (href !== "/" && currentPath.startsWith(href))
                ? "text-primary"
                : "text-gray-600 hover:text-primary",
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
