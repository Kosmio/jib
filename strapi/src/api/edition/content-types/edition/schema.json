{
  "kind": "collectionType",
  "collectionName": "editions",
  "info": {
    "singularName": "edition",
    "pluralName": "editions",
    "displayName": "Édition",
    "description": "Les éditions régionales des Journées de l'Innovation Filière Bois"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "year": {
      "type": "integer",
      "required": true
    },
    "region": {
      "type": "enumeration",
      "enum": [
        "normandie",
        "region-sud",
        "nouvelle-aquitaine",
        "auvergne-rhone-alpes",
        "ile-de-france",
        "bretagne",
        "occitanie",
        "grand-est",
        "hauts-de-france",
        "pays-de-la-loire",
        "bourgogne-franche-comte",
        "centre-val-de-loire",
        "corse"
      ],
      "required": true
    },
    "date": {
      "type": "date",
      "required": true
    },
    "city": {
      "type": "string",
      "required": true
    },
    "edition_status": {
      "type": "enumeration",
      "enum": ["a-venir", "inscriptions-ouvertes", "complet", "passee"],
      "default": "a-venir",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "inscription_url": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "lieux": {
      "type": "component",
      "component": "edition.lieu",
      "repeatable": true
    },
    "programme_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::programme-item.programme-item",
      "mappedBy": "edition"
    },
    "partenaires": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::partenaire.partenaire",
      "inversedBy": "editions"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "video_urls": {
      "type": "text"
    },
    "summary": {
      "type": "richtext"
    },
    "testimonials": {
      "type": "richtext"
    }
  }
}
