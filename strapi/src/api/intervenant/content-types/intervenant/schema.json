{
  "kind": "collectionType",
  "collectionName": "intervenants",
  "info": {
    "singularName": "intervenant",
    "pluralName": "intervenants",
    "displayName": "Intervenant"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["personne", "organisation"],
      "default": "personne"
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "title": {
      "type": "string"
    },
    "organization": {
      "type": "string",
      "required": true
    },
    "bio": {
      "type": "richtext"
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "topic": {
      "type": "string"
    },
    "linkedin_url": {
      "type": "string"
    },
    "website": {
      "type": "string"
    },
    "category": {
      "type": "enumeration",
      "enum": ["entrepreneur", "chercheur", "financeur", "institutionnel", "organisateur"]
    },
    "video_url": {
      "type": "string"
    },
    "long_description": {
      "type": "richtext"
    },
    "partenaire": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::partenaire.partenaire",
      "inversedBy": "intervenants"
    },
    "programme_items": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::programme-item.programme-item",
      "mappedBy": "intervenants"
    }
  }
}
