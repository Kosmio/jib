{
  "kind": "collectionType",
  "collectionName": "programme_items",
  "info": {
    "singularName": "programme-item",
    "pluralName": "programme-items",
    "displayName": "Élément de programme",
    "description": "Les interventions et moments du programme d'une édition"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "start_time": {
      "type": "string",
      "required": true
    },
    "end_time": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    },
    "order": {
      "type": "integer"
    },
    "edition": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::edition.edition",
      "inversedBy": "programme_items"
    },
    "intervenants": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::intervenant.intervenant",
      "inversedBy": "programme_items"
    },
    "organisations": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::organisation.organisation",
      "inversedBy": "programme_items"
    }
  }
}
