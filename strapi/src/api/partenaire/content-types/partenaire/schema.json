{
  "kind": "collectionType",
  "collectionName": "partenaires",
  "info": {
    "singularName": "partenaire",
    "pluralName": "partenaires",
    "displayName": "Partenariat",
    "description": "Lien de partenariat entre une organisation et les éditions"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "display_name": {
      "type": "string"
    },
    "role": {
      "type": "enumeration",
      "enum": ["soutien", "co-organisateur", "institutionnel", "prive"],
      "required": true
    },
    "organisation": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::organisation.organisation",
      "inversedBy": "partenariats"
    },
    "editions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::edition.edition",
      "mappedBy": "partenaires"
    }
  }
}
